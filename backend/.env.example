PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret

# Local Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studyhub
DB_USER=postgres
DB_PASSWORD=postgres_password

# Or use a single hosted Postgres URL instead
# DATABASE_URL=postgresql://user:password@host:5432/studyhub
# DB_SSL=require

DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000

# Comma-separated frontend origins for production
CORS_ORIGIN=http://localhost:5173

# Optional AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional Google sign in
GOOGLE_CLIENT_ID=

# Optional browser push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com
